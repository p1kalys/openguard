    "safety",
    "llm",
    "security",
    "openai",
    "chat",
    "json",
    "completions"
  ],
  "author": "Pavan Emani",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0",
    "vitest": "^1.6.1"
  },
  "dependencies": {
    "zod": "^3.25.76"
  }
}